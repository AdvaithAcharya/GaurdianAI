# GuardianAI Backend Configuration

# Application
DEBUG=True
HOST=0.0.0.0
PORT=8000

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=guardianai

# Firebase (for push notifications)
FIREBASE_CREDENTIALS_PATH=path/to/firebase-credentials.json
FIREBASE_PROJECT_ID=your-project-id

# Twilio (for phone calls)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Alert Settings
ALERT_ESCALATION_TIMEOUT=30
MAX_ESCALATION_ATTEMPTS=3

# AI Detection Settings
GESTURE_THRESHOLD=3
GESTURE_TIME_WINDOW=5
FALL_HEIGHT_THRESHOLD=0.3
VOICE_KEYWORDS=["help", "nurse", "doctor", "emergency"]

# Video Processing
MAX_CONCURRENT_STREAMS=10
FRAME_SKIP=2
VIDEO_QUALITY=50

# Privacy
ENABLE_FACE_BLUR=True
BLUR_KERNEL_SIZE=51

# Vosk Model Path (download from https://alphacephei.com/vosk/models)
VOSK_MODEL_PATH=models/vosk-model-small-en-us-0.15
