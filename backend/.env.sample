# Sample environment configuration for GuardianAI backend (Twilio + MongoDB)

# Application
DEBUG=False
HOST=0.0.0.0
PORT=8000

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/?
MONGODB_DB_NAME=guardianai

# Twilio (voice escalation)
# You can also provide TWILIO_SID/TWILIO_TOKEN; both formats are supported
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Alternative variable names (optional)
TWILIO_SID=
TWILIO_TOKEN=

# Phone normalization
DEFAULT_COUNTRY_CODE=+1

# AI model paths (if needed by MediaPipe tasks)
POSE_LANDMARKER_TASK=models/pose_landmarker_full.task
